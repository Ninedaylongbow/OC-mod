<?xml version="1.0" encoding="utf-8" ?>
<Defs>
	<PawnKindDef>
		<race>Pigeon_SuccubusOC_Race</race>
		<combatPower>40</combatPower>
		<isFighter>false</isFighter>
		<apparelIgnoreSeasons>false</apparelIgnoreSeasons>
		<forceNormalGearQuality>true</forceNormalGearQuality>
		<defName>PigeonOCSuccubus</defName>
		<label>레티시아</label>
		<defaultFactionType>PlayerColony</defaultFactionType>
		<backstoryFiltersOverride>
			<li>
				<categories>
					<li>Pigeon_SuccubusOC_BackStroy</li>
				</categories>
			</li>
		</backstoryFiltersOverride>
		<apparelTags>
			<li>Pigeon_Succubus</li>
		</apparelTags>
		<apparelRequired>
			<li>Pigeon_Succubus_Apparel</li>
			<li>Pigeon_Succubus_Hat</li>
		</apparelRequired>
		<minGenerationAge>18</minGenerationAge>
		<maxGenerationAge>35</maxGenerationAge>
		<apparelAllowHeadgearChance>0</apparelAllowHeadgearChance>
		<apparelMoney>
			<min>800000</min>
			<max>1200000</max>
		</apparelMoney>
		<backstoryCryptosleepCommonality>0</backstoryCryptosleepCommonality>
		<initialWillRange>1~3</initialWillRange>
		<initialResistanceRange>13~21</initialResistanceRange>
		<startingHediffs>
			<li>
				<def>Pigeon_SuccubusOC_Hediff</def>
			</li>
		</startingHediffs>
	</PawnKindDef>
	<HediffDef>
		<defName>Pigeon_SuccubusOC_Hediff</defName>
		<label>Pigeon_SuccubusOC_Hediff</label>
		<description>부여되는 순간 20살로 신체가 재구성됩니다. 이후 정상적으로 노화합니다.</description>
		<hediffClass>HediffWithComps</hediffClass>
		<comps>
			<li Class="OC_Mod.HediffCompProperties_FreezeAge">
				<permanent>false</permanent>
				<!-- 한 번만 고정(회춘) 후 정상 노화 -->
				<targetAgeYears>20</targetAgeYears>
				<!-- 20살로 세팅 -->
			</li>
		</comps>
	</HediffDef>
	<RulePackDef>
		<defName>Pigeon_SuccubusOC_Race_NameMaker</defName>
		<rulePack>
			<rulesStrings>
				<li>r_name(p=2)->[Pigeon_SuccubusOC_FirstName][Pigeon_SuccubusOC_LastName]</li>
				<li>Pigeon_SuccubusOC_nickName->레티시아</li>
				<li>Pigeon_SuccubusOC_FirstName->레티</li>
				<li>Pigeon_SuccubusOC_LastName->시아</li>
			</rulesStrings>
		</rulePack>
	</RulePackDef>

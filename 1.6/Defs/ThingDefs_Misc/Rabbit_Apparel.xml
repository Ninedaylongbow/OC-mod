<?xml version="1.0" encoding="utf-8"?>
<Defs>
	<ThingDef ParentName="ApparelMakeableBase">
		<defName>Pigeon_Rabbit_ApparelA</defName>
		<label>마법사 의상 </label>
    <description>예쁘고 귀여워!</description>
    <graphicData>
			<texPath>Things/Apparel/Rabbit/RabbitA</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <shaderType>CutoutComplex</shaderType>
		</graphicData>
    <generateCommonality>0.0001</generateCommonality>
	  <!-- <destroyOnDrop>true</destroyOnDrop> -->
    <smeltable>false</smeltable>
		<costStuffCount>0</costStuffCount>
    <useHitPoints>false</useHitPoints>
		<tradeTags Inherit="False"/>
    <tradeability>None</tradeability>
    <thingCategories>
      <li>ApparelArmor</li>
    </thingCategories>
    <apparel>
      <tags>
			  <li>Pigeon_Rabbit</li>
      </tags>
			<bodyPartGroups>
        <li>FullHead</li>
				<li>Neck</li>
				<li>Torso</li>
				<li>Shoulders</li>
				<li>Arms</li>
				<li>Legs</li>
			</bodyPartGroups>
      <renderSkipFlags>
        <li>None</li>
      </renderSkipFlags>
			<wornGraphicPath>Things/Apparel/Rabbit/RabbitA</wornGraphicPath>
			<layers>
        <li>Middle</li>
			</layers>
      <canBeDesiredForIdeo>false</canBeDesiredForIdeo>
      <canBeGeneratedToSatisfyWarmth>false</canBeGeneratedToSatisfyWarmth>
      <canBeGeneratedToSatisfyToxicEnvironmentResistance>false</canBeGeneratedToSatisfyToxicEnvironmentResistance>
      <useWornGraphicMask>true</useWornGraphicMask>
    </apparel>
    <colorGenerator Class="ColorGenerator_Options">
      <options>
        <li>
          <weight>10</weight>
          <only>(1,1,1,1)</only>
        </li>
      </options>
    </colorGenerator>
    <recipeMaker Inherit="False" IsNull="True"/>
    <costList Inherit="False"/>
		<statBases>
			<WorkToMake>25000</WorkToMake>
			<Mass>0.5</Mass>
			<Flammability>0</Flammability>
			<EquipDelay>1</EquipDelay>
      <DeteriorationRate>0</DeteriorationRate>
      <ArmorRating_Sharp>1.06</ArmorRating_Sharp>
      <ArmorRating_Blunt>0.45</ArmorRating_Blunt>
      <ArmorRating_Heat>0.54</ArmorRating_Heat>
      <Insulation_Cold>68</Insulation_Cold>
      <Insulation_Heat>10</Insulation_Heat>
		</statBases>
		<equippedStatOffsets>
      <SlaveSuppressionOffset MayRequire="Ludeon.RimWorld.Ideology">-0.3</SlaveSuppressionOffset>
      <VacuumResistance MayRequire="Ludeon.RimWorld.Odyssey">1</VacuumResistance>
		</equippedStatOffsets>
	</ThingDef>

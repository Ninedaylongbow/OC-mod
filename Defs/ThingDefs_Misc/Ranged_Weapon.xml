<?xml version="1.0" encoding="utf-8" ?>
<Defs>
  <ThingDef ParentName="BaseHumanMakeableGun">
    <defName>PigeonOC_RabbitWeapon</defName>
    <label>RabbitWeapon</label>
    <description>。</description>
    <graphicData>
      <texPath>Things/Weapon/RabbitWeapon</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <soundInteract>Interact_SMG</soundInteract>
    <techLevel>Spacer</techLevel>
    <weaponTags>
      <li>Rifile</li>
      <li>PinBalisticWeapon</li>
    </weaponTags>
    <statBases>
      <WorkToMake>680</WorkToMake>
      <Mass>3.6</Mass>
      <AccuracyTouch>0.70</AccuracyTouch>
      <AccuracyShort>0.70</AccuracyShort>
      <AccuracyMedium>0.40</AccuracyMedium>
      <AccuracyLong>0.30</AccuracyLong>
      <RangedWeapon_Cooldown>1.5</RangedWeapon_Cooldown>
    </statBases>
    <verbs>
      <li>
        <verbClass>Verb_Shoot</verbClass>
        <hasStandardCommand>true</hasStandardCommand>
        <defaultProjectile>PigeonOCRabbitBullet</defaultProjectile>
        <warmupTime>1.2</warmupTime>
        <range>25</range>
        <soundCast>Shot_shotgun</soundCast>
        <soundCastTail>GunTail_Light</soundCastTail>
        <muzzleFlashScale>14</muzzleFlashScale>
        <burstShotCount>3</burstShotCount>
        <ticksBetweenBurstShots>9</ticksBetweenBurstShots>
      </li>
    </verbs>
    <recipeMaker>
      <skillRequirements>
        <Crafting>7</Crafting>
      </skillRequirements>
      <recipeUsers Inherit="False">
        <li>TableMachining</li>
      </recipeUsers>
    </recipeMaker>
    <costList>
      <Steel>75</Steel>
      <Chemfuel>15</Chemfuel>
      <ComponentIndustrial>5</ComponentIndustrial>
    </costList>
    <tools>
      <li>
        <label>grip</label>
        <capacities>
          <li>Blunt</li>
        </capacities>
        <power>9.3</power>
        <cooldownTime>2</cooldownTime>
      </li>
      <li>
        <label>barrel</label>
        <capacities>
          <li>Blunt</li>
          <li>Poke</li>
        </capacities>
        <power>9.3</power>
        <cooldownTime>2</cooldownTime>
      </li>
    </tools>
  </ThingDef>
  <ThingDef ParentName="BaseBullet">
    <defName>PigeonOCRabbitBullet</defName>
    <label>子弹</label>
    <graphicData>
      <texPath>Things/Projectile/Bullet_Small</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <projectile>
      <damageDef>Bullet</damageDef>
      <damageAmountBase>16</damageAmountBase>
      <armorPenetrationBase>0.16</armorPenetrationBase>
      <stoppingPower>0.8</stoppingPower>
      <speed>60</speed>
    </projectile>
  </ThingDef>

